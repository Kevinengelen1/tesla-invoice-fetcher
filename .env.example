# Tesla Fleet API credentials (from developer.tesla.com)
TESLA_CLIENT_ID=your-client-id-here
TESLA_CLIENT_SECRET=ta-secret.your-secret-here

# Fleet API redirect URI (must be registered at developer.tesla.com).
# Tesla only accepts localhost as redirect host (private IPs are rejected).
# For local dev: omit this line — auto-detected as http://localhost:5000/auth/fleet/callback
# For Docker accessed from another machine: set to your registered localhost URI
TESLA_REDIRECT_URI=http://localhost:8080/callback

# Your Tesla account email (required for Premium Connectivity invoices)
TESLA_EMAIL=your-email@example.com

# Your vehicle VIN(s), comma-separated (find in Tesla app under vehicle info)
TESLA_VINS=

# Region: na (North America), eu (Europe), cn (China)
TESLA_REGION=eu

# Invoice storage — omit when running in Docker (set via docker-compose environment)
INVOICE_OUTPUT_DIR=./invoices

# Invoice filename pattern (without .pdf). Available placeholders:
#   {date}  — charge/invoice date as YYYY-MM-DD
#   {label} — "Superchargen" or "Premium Connectivity"
#   {name}  — original filename from Tesla (without extension)
#   {id}    — Tesla content/invoice ID
# INVOICE_NAME_PATTERN={date} - Tesla - {label} {name}

# Email settings (optional — leave blank to disable email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
