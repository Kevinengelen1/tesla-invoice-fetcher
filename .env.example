# =============================================================================
# Tesla Invoice Fetcher - Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# --- Server ---
NODE_ENV=production
PORT=3001
SESSION_SECRET=            # Auto-generated if empty on first run
BASE_URL=http://localhost:3001

# --- Database ---
# Set DATABASE_TYPE=mysql to use MySQL/MariaDB instead of SQLite.
# These values are read from environment ONLY and cannot be changed via the UI.
DATABASE_TYPE=sqlite

# SQLite (used when DATABASE_TYPE=sqlite)
DATABASE_PATH=./data/tesla-invoices.sqlite

# MySQL / MariaDB (used when DATABASE_TYPE=mysql)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=tesla
# MYSQL_PASS=
# MYSQL_DATABASE=tesla_invoices

# --- Invoice Storage ---
INVOICE_STORAGE_DIR=./invoices

# --- Tesla API ---
# Tesla developer app credentials are managed in the web UI under Tesla Authentication.
TOKEN_ENCRYPTION_KEY=      # Auto-generated if empty on first run

# --- OIDC Authentication (optional) ---
OIDC_ENABLED=false
OIDC_ISSUER=               # e.g. https://authentik.example.com/application/o/tesla-invoices/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3001/api/auth/oidc/callback

# --- Email Notifications (optional) ---
EMAIL_ENABLED=false
EMAIL_TO=
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# --- Scheduling ---
FETCH_SCHEDULE_CRON=       # e.g. "0 6 * * *" for daily at 6 AM
AUTO_FETCH_ENABLED=false
